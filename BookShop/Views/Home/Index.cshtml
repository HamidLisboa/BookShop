@using Microsoft.AspNetCore.Identity

@model BookDisplayModel
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager
@{
    ViewData["Title"] = "Home Page";
   
}
<div class="my-2">
<h1 class="col-12 text-center mt-2">Welcome to Online Book Shop</h1>
</div>
<div class="d-flex justify-content-center mt-2">
<form asp-action="index" class="row row-cols-lg-auto g-3 align-items-center w-100" style="max-width:900px;">
  <div class="col-12">
    <label class="visually-hidden" for="searchTerm">Search by Title</label>
    <div class="input-group">
      @* <div class="input-group-text"></div> *@
      <input type="text" class="form-control" value="@Model.searchTerm" id="searchTerm" name="searchTerm" placeholder="Search by Title">
    </div>
  </div>

  <div class="col-12">
    <label class="visually-hidden" for="genreId">Genre</label>
    <select asp-for="genreId" class="form-select" id="genreId" name="genreId">        
        <option value="">Select Genre</option>        
            @foreach(var genre in Model.Genres)        
                {        
                    <option value="@genre.id">@genre.GenreName</option>        
                }        
    </select>        
  </div>

  
  <div class="col-12">
    <button type="submit" class="btn btn-primary">Filter</button>
    <a href="/Home/Index" class="btn btn-dark">Reset</a>
  </div>
</form>
</div>
<div class="d-flex flex-wrap justify-content-center my-4 mt-3">
    @foreach(var book in Model.Books)
    {
        <div class="m-2 mb-3">
            <div class="card" style="width: 20rem;">
                <div class="card-body text-center">
                    <h5 class="card-title">@book.BookName</h5>
                    <img src="@book.Image" class="mx-auto d-block img-fluid" alt="@book.BookName" style="height:100%; width:auto; object-fit:cover;">
                    <p class="card-text">Author: @book.AuthorName<br />Genre: @book.GenreName <br />Price: @book.Price €</p>
                    <button type="button" onclick="add(@book.id)" class="btn btn-primary d-block mx-auto"><i class="bi bi-cart-plus"></i></button>
                </div>
            </div>
        </div>
    }
</div>
@section Scripts{
    <script>
        
        async function add(bookId) {
            var usernameEl = document.getElementById("username");
            if(usernameEl==null){
            window.location.href = "/Identity/Account/Login";
            }
            try {
                var response = await fetch(`/Cart/AddItemtoCart?bookId=${bookId}`);
                if (response.status == 200) {
                    var result = await response.json();
                    var cartCountEl = document.getElementById("cartCount");
                    cartCountEl.innerHTML = result;
                }
            }
            catch (err) {
                console.log(err);
            }
        }
    </script>
}